---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings } from '../lib/repo';

export const prerender = false;
const settings = getSettings();
const paragraphs = (settings.about || '').split(/\n{2,}/).filter(Boolean);
---

<BaseLayout title="About" description={settings.about}>
  <h1 class="mb-8 font-serif text-4xl leading-[1.04]">About</h1>
  <div class="prose">
    {paragraphs.map((p) => <p>{p}</p>)}
    {settings.instagram && (
      <p>
        Elsewhere: <a href={`https://instagram.com/${settings.instagram}`} target="_blank" rel="noopener">@{settings.instagram}</a>.
      </p>
    )}
  </div>
</BaseLayout>
